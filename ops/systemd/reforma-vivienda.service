[Unit]
Description=COMOPS Reforma Vivienda
After=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/corium/Documents/Quimera/reforma-vivienda
ExecStartPre=/bin/sh -lc 'until /usr/bin/docker info >/dev/null 2>&1; do sleep 2; done'
ExecStart=/usr/bin/docker compose up -d --remove-orphans
ExecStop=/usr/bin/docker compose stop
TimeoutStartSec=180
TimeoutStopSec=60

[Install]
WantedBy=default.target
